; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Match-3 Game"
run/main_scene="res://scenes/MainGame.tscn"
config/features=PackedStringArray("4.5", "Mobile")
boot_splash/bg_color=Color(0.2, 0.15, 0.35, 1)
boot_splash/fullsize=false
boot_splash/use_filter=false
boot_splash/image="uid://cj0lb5n4deesr"
config/icon="res://icon.svg"

[autoload]

TranslationBootstrap="*res://systems/TranslationBootstrap.gd"
GameState="*res://meta/profile/GameState.gd"
AdMobManager="*res://systems/AdMobManager.gd"
LevelManager="*res://systems/LevelManager.gd"
ThemeManager="*res://systems/ThemeManager.gd"
RewardManager="*res://meta/rewards/RewardManager.gd"
GameRunState="*res://games/match3/GameRunState.gd"
AudioManager="*res://systems/AudioManager.gd"
StarRatingManager="*res://meta/rewards/StarRatingManager.gd"
EffectResolver="*res://systems/EffectResolver.gd"
AssetRegistry="*res://systems/AssetRegistry.gd"
VisualAnchorManager="*res://scripts/VisualAnchorManager.gd"
DLCConfig="*res://systems/DLCConfig.gd"
DLCManager="*res://systems/DLCManager.gd"
NarrativeStageManager="*res://experience/narrative/NarrativeStageManager.gd"
ExperienceDirector="*res://experience/ExperienceDirector.gd"
CollectionManager="*res://meta/systems/CollectionManager.gd"
VibrationManager="*res://systems/VibrationManager.gd"
PageManager="*res://scripts/ui/PageManager.gd"
NodeResolvers="*res://scripts/helpers/node_resolvers.gd"
ProgressManager="*res://meta/progression/ProgressManager.gd"
GalleryManager="*res://meta/progression/GalleryManager.gd"
GalleryImageLoader="*res://meta/systems/GalleryImageLoader.gd"
StoryManager="*res://meta/systems/StoryManager.gd"
AchievementManager="*res://meta/progression/AchievementManager.gd"
ProfileManager="*res://meta/progression/ProfileManager.gd"
ShardDropSystem="*res://meta/systems/ShardDropSystem.gd"
ShardToastNotifier="*res://scripts/ui/ShardToastNotifier.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/size/mode=2
window/stretch/mode="viewport"
window/handheld/orientation=1

[editor_plugins]

enabled=PackedStringArray("res://addons/definition_audit/plugin.cfg", "res://addons/droid_admob/plugin.cfg")

[internationalization]

locale/translations=PackedStringArray("res://data/translations/translations.en.translation", "res://data/translations/translations.es.translation", "res://data/translations/translations.pt.translation", "res://data/translations/translations.fr.translation")

[match3]

audio/music_volume=70
audio/sfx_volume=80
audio/music_enabled=false
audio/sfx_enabled=false
audio/muted=false

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
