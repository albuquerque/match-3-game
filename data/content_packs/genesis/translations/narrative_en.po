msgstr ""

msgid "NARRATIVE_NEW_HEAVENS_NEW_EARTH_MAIN"
msgstr ""

msgid "NARRATIVE_NEW_PHARAOH_MAIN"
msgstr "A new king arose over Egypt,\nwho did not know Joseph.\n\nHe feared the Israelites' numbers."

msgid "NARRATIVE_NOAH_CALLED_MAIN"
msgstr "God saw the wickedness of mankind\nand decided to flood the earth.\n\nBut Noah found favor in God's eyes."

msgid "NARRATIVE_PARABLE_OF_THE_LOST_SHEEP_MAIN"
msgstr ""

msgid "NARRATIVE_PARABLE_OF_THE_SOWER_MAIN"
msgstr ""

msgid "NARRATIVE_PARTING_OF_THE_RED_SEA_MAIN"
msgstr ""

