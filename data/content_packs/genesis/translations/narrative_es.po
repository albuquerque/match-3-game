msgstr ""

msgid "NARRATIVE_JOSEPH_SOLD_DESC"
msgstr "Traicionado por sus hermanos"

msgid "NARRATIVE_JOSEPH_SOLD_MAIN"
msgstr "Joseph's brothers sold him to traders\nand told their father he was dead.\n\nBetrayal by blood."

msgid "NARRATIVE_JOSEPH_SOLD_NAME"
msgstr "José vendido como esclavo"

