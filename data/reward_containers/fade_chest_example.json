{
	"container_id": "fade_chest_example",
	"description": "Example using two full images (closed → open) with fade transition",
	"theme": "universal",

	"visual": {
		"layers": [
			{
				"type": "sprite",
				"texture": "res://textures/reward_containers/treasure_chest_closed.png",
				"z_index": 1,
				"pivot": "center",
				"scale": 0.5,
				"comment": "CLOSED chest - starts visible, will fade out"
			},
			{
				"type": "sprite",
				"texture": "res://textures/reward_containers/treasure_chest_open.png",
				"z_index": 0,
				"pivot": "center",
				"scale": 0.5,
				"alpha": 0.0,
				"comment": "OPEN chest - starts invisible (alpha 0), will fade in"
			}
		],
		"colors": {
			"primary": "${theme.primary_color}",
			"accent": "${theme.accent_color}",
			"particle": "${theme.particle_color}"
		}
	},

	"animations": {
		"idle": {
			"type": "float",
			"amplitude": 3,
			"duration": 2.0
		},
		"opening": {
			"type": "sequence",
			"steps": [
				{
					"action": "shake",
					"intensity": 8,
					"duration": 0.25,
					"comment": "Shake both images"
				},
				{
					"action": "fade_layer",
					"layer": 0,
					"from": 1.0,
					"to": 0.0,
					"duration": 0.2,
					"comment": "Fade OUT closed chest"
				},
				{
					"action": "fade_layer",
					"layer": 1,
					"from": 0.0,
					"to": 1.0,
					"duration": 0.2,
					"comment": "Fade IN open chest (runs AFTER previous fade completes)"
				}
			]
		},
		"reveal": {
			"type": "spawn_rewards",
			"pattern": "interactive",
			"anchor": [0, -60],
			"comment": "Interactive reveal - one reward at a time, wait for CLAIM tap"
		},
		"closing": {
			"type": "sequence",
			"steps": [
				{
					"action": "scale",
					"from": 1.0,
					"to": 0.0,
					"duration": 0.4
				}
			]
		}
	},

	"particles": {
		"on_open": {
			"texture": "res://particles/sparkle.png",
			"count": 25,
			"spread": 360,
			"speed": 120,
			"lifetime": 1.0,
			"color": "${theme.particle_color}"
		},
		"on_reveal": {
			"texture": "res://particles/coin_shine.png",
			"count": 15,
			"spread": 180,
			"speed": 80,
			"lifetime": 0.8,
			"color": "${theme.gold_color}"
		}
	},

	"sounds": {
		"opening": "booster_bomb_3x3",
		"reveal": "match",
		"complete": "combo"
	}
}
